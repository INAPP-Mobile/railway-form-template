# Required
DATABASE_URL=postgresql://user:password@host:5432/railway
ADMIN_PASSWORD=change_me

# CAPTCHA (optional - Cap is the primary provider)
# CAP_ENDPOINT=http://localhost:8787
# CAP_SECRET_KEY=your_cap_secret
# CAPTCHA_MODE=auto

# Email notifications (optional - SendGrid or SMTP)
# FORM_RECIPIENT_EMAIL=you@example.com
# SENDGRID_API_KEY=SG.xxxxx
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_smtp_password
# FROM_EMAIL=noreply@contact-form.app

# Rate limiting
# RATE_LIMIT=10
# RATE_LIMIT_BACKEND=memory

# Session
# SESSION_SECRET_KEY=random_secret_key
